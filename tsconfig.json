{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "dom"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@plataforma/api/*": ["./apps/api/src/*"],
      "@plataforma/web/*": ["./apps/web/src/*"],
      "@plataforma/shared/*": ["./packages/shared/src/*"]
    }
  },
  "include": [],
  "exclude": ["node_modules", "dist", "build", ".next"]
}