{
  "name": "plataforma-atencion-inteligente",
  "version": "1.0.0",
  "private": true,
  "description": "SaaS platform for intelligent customer service",
  "packageManager": "pnpm@8.15.9",

  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:api": "nest build apps/api",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @plataforma/api db:generate",
    "db:push": "pnpm --filter @plataforma/api db:push",
    "db:migrate": "pnpm --filter @plataforma/api db:migrate",
    "db:studio": "pnpm --filter @plataforma/api db:studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}