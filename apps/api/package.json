    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^9.0.8",
    "eslint": "^8.57.0",
    "prisma": "^5.10.0",
    "ts-loader": "^9.5.7",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
