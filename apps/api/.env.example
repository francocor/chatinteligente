# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/plataforma_atencion"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"

# Server
PORT=4000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# AI Provider (optional - uses mock provider if not provided)
AI_PROVIDER="mock"
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-4o-mini"

# AI Limits and Configuration
AI_TIMEOUT_MS=10000
MAX_AI_MESSAGE_LENGTH=1000
MAX_AI_RESPONSE_LENGTH=1500
MAX_AI_REQUESTS_PER_MINUTE=10
MAX_AI_REQUESTS_PER_DAY=200

# WhatsApp (optional - for WhatsApp integration)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"

# Stripe (optional - for billing)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email (optional)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# S3 Storage (optional)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
S3_BUCKET=""